APP_NAME=Research Feed App
APP_ENV=production
BASE_URL=https://tvoje-aplikace.onrender.com
DATABASE_URL=postgresql+psycopg://USERNAME:PASSWORD@HOST/DBNAME?sslmode=require
SESSION_COOKIE_NAME=research_session
SYNC_SECRET=replace-this-with-a-long-random-string
BOOTSTRAP_ADMIN_USERNAME=Admin
BOOTSTRAP_ADMIN_EMAIL=admin@example.local
BOOTSTRAP_ADMIN_PASSWORD=Ahojky12345
BOOTSTRAP_USER_USERNAME=User
BOOTSTRAP_USER_EMAIL=user@example.local
BOOTSTRAP_USER_PASSWORD=Ahojky54321
AUTO_SEED_ON_STARTUP=true
AUTO_SYNC_ON_STARTUP=false
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
AUDIO_TTS_LANG=cs
AUDIO_URL_LIMIT=3


ALLOW_PUBLIC_REGISTRATION=false
BOOTSTRAP_USER_ENABLED=false
VIP_SSO_ENABLED=true
VIP_SSO_SHARED_SECRET=hesloprovstupdoresrse
VIP_SSO_ISSUER=vip-klub
VIP_INTERNAL_SHARED_SECRET=hesloprovstupdoresrse